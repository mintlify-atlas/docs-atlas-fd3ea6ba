  "keyFeatures": [
    "WAF and Cloudflare bypass using Camoufox headless browser with real browser fingerprinting",
    "Asynchronous plugin brute-force scanning across ~110,000 historical and ~55,000 active plugins",
    "Multi-method user enumeration: REST API, author archive probing, oEmbed, RSS feed, and passive HTML scan",
    "WPScan Vulnerability Database integration for CVE lookup and version-aware vulnerability filtering",
    "WordPress version detection via meta generator and RSS feed with latest-version comparison",
    "Theme detection with style.css metadata parsing and version confidence scoring",
    "Multisite detection via wp-signup.php and wp-activate.php",
    "Config backup file discovery with soft-404 baseline filtering",
    "Stealth mode with configurable random delays and thread throttling",
    "Docker support with named volumes for persistent WPScan metadata"
  ],
  "publicApiSurface": [
    "wpx -u <URL> [options]",
    "--api-key KEY",
    "--enumerate / -e p,u,cb,t",
    "--threads / -t N",
    "--plugins-limit N",
    "--full-scan",
    "--users-limit N",
    "--no-browser",
    "--stealth [N]",
    "--idle-timeout N",
    "--quiet / -q",
    "--output / -o FILE",
    "--update",
    "data/wpx_fetch_plugins.py --sort-by score|active_installs|downloaded",
    "data/wpx_fetch_plugins.py --active-limit N --dead-limit N"
  ]
}
